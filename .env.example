# TechSpar 启动配置 —— 这里只放「引导项」，不放任何 API Key。
#
# LLM / Embedding / DashScope / Tavily / 阿里云 OSS / 腾讯云 VPR 等所有密钥，
# 都由每个用户登录后在「设置」里自己填（首次登录有两步引导带你配 LLM + Embedding）。
# 部署者也一样：这里只配好管理员账号，模型 key 进 UI，互不共享、各算各的账。

# Auth
JWT_SECRET=change-me-in-production
DEFAULT_EMAIL=admin@techspar.local
DEFAULT_PASSWORD=admin123
DEFAULT_NAME=admin
# 是否允许新用户在登录页注册。false 时只有上面的 DEFAULT_EMAIL/PASSWORD 能登录。
# 也可在设置页“账户”标签里切换，运行时即时生效（此文件只用于首次启动的初值）。
ALLOW_REGISTRATION=false

# Interview tuning (optional)
MAX_QUESTIONS_PER_PHASE=5
MAX_DRILL_QUESTIONS=15
